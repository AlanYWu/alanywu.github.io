---
import EmailLink from "./EmailLink.astro";
const year = new Date().getFullYear();
---
<footer class="mt-32 py-10 px-6 md:px-10 border-t border-[var(--color-rule)] text-xs font-mono text-[var(--color-mute)] flex flex-wrap justify-between gap-4">
  <span>© {year} alan wu · from one, many.</span>
  <span class="flex gap-5 items-baseline">
    <a class="wake grow-line" href="https://github.com/AlanYWu">github</a>
    <EmailLink label="email" className="wake grow-line" />
  </span>
</footer>
