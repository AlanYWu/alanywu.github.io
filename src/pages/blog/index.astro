---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort((a, b) => +b.data.date - +a.data.date);
const fmt = (d: Date) => d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---
<Layout title="blog · alan wu" current="blog">
  <header class="pt-10 max-w-2xl">
    <h1 class="font-serif text-4xl md:text-5xl tracking-tight">Blog</h1>
    <p class="mt-3 text-[var(--color-mute)]">Essays. Half-formed thoughts that grew into longer ones.</p>
  </header>

  <ul class="mt-12 divide-y divide-[var(--color-rule)]">
    {posts.map(p => (
      <li>
        <a href={`/blog/${p.id}/`} class="block py-8 group wake">
          <h2 class="font-serif text-2xl group-hover:text-[var(--color-life)] transition-colors">{p.data.title}</h2>
          <p class="font-mono text-xs text-[var(--color-mute)] mt-2">{fmt(p.data.date)}</p>
          <p class="mt-3 text-[var(--color-mute)] max-w-2xl">{p.data.summary}</p>
        </a>
      </li>
    ))}
  </ul>
</Layout>
