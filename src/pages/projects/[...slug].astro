---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Layout title={`${entry.data.title} · alan wu`} current="projects">
  <article class="pt-10 max-w-3xl">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-mute)]">{entry.data.year} · project</p>
    <h1 class="mt-3 font-serif">{entry.data.title}</h1>
    <p class="summary mt-3">{entry.data.summary}</p>

    <div class="mt-4 flex gap-4 font-mono text-xs">
      {entry.data.repo && <a class="grow-line wake" href={entry.data.repo}>repo ↗</a>}
      {entry.data.demo && <a class="grow-line wake" href={entry.data.demo}>demo ↗</a>}
    </div>

    <div class="prose prose-neutral mt-10 text-base leading-[1.7]">
      <Content />
    </div>
  </article>
</Layout>
