---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const updates = await getCollection("updates");
  return updates.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = entry.data.date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
---
<Layout title={`${entry.data.title} · updates`} current="updates">
  <article class="pt-10 max-w-2xl">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-mute)]">{entry.data.week} · {fmt}</p>
    <h1 class="mt-3 font-serif text-4xl tracking-tight">{entry.data.title}</h1>
    <div class="prose prose-neutral mt-10 font-serif text-lg leading-relaxed">
      <Content />
    </div>
    <a href="/updates/" class="inline-block mt-16 grow-line wake font-mono text-sm">← all updates</a>
  </article>
</Layout>
