---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const updates = (await getCollection("updates"))
  .sort((a, b) => +b.data.date - +a.data.date);

const fmt = (d: Date) => d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
---
<Layout title="updates · alan wu" current="updates">
  <header class="pt-10 max-w-2xl">
    <h1 class="font-serif text-4xl md:text-5xl tracking-tight">Weekly updates</h1>
    <p class="mt-3 text-[var(--color-mute)]">
      One cell divides into two. Each week here is a small division, a record
      of what I built, what I read, and what surprised me.
    </p>
  </header>

  <ol class="mt-14 relative border-l border-[var(--color-rule)] pl-8 space-y-12">
    {updates.map(u => (
      <li class="relative">
        <span class="absolute -left-[37px] top-2 w-3 h-3 rounded-full bg-[var(--color-paper)] border border-[var(--color-life)]"></span>
        <a href={`/updates/${u.id}/`} class="block group wake">
          <div class="flex items-baseline justify-between gap-4">
            <h2 class="font-serif text-2xl group-hover:text-[var(--color-life)] transition-colors">{u.data.title}</h2>
            <span class="font-mono text-xs text-[var(--color-mute)]">{u.data.week}</span>
          </div>
          <p class="font-mono text-xs text-[var(--color-mute)] mt-1">{fmt(u.data.date)}{u.data.mood ? ` · ${u.data.mood}` : ""}</p>
        </a>
      </li>
    ))}
  </ol>

  <p class="mt-20 font-mono text-xs text-[var(--color-mute)]">
    Add a new entry by dropping <code>YYYY-WW.mdx</code> into <code>src/content/updates/</code>.
  </p>
</Layout>
